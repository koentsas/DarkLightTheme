{
    "name": "darklight-hybrid-theme",
    "displayName": "DarkLight Hybrid Theme",
    "description": "A VS Code theme with a dark workbench and a light editor.",
    "version": "0.0.1",
    "publisher": "tsasson",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/koentsas/DarkLightTheme.git"
    },
    "homepage": "https://github.com/koentsas/DarkLightTheme",
    "bugs": {
        "url": "https://github.com/koentsas/DarkLightTheme/issues"
    },
    "icon": "assets/icon.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Themes"
    ],
    "keywords": [
        "theme",
        "dark",
        "light",
        "hybrid",
        "editor",
        "workbench"
    ],
    "contributes": {
        "themes": [
            {
                "label": "DarkLight Hybrid",
                "uiTheme": "vs-dark",
                "path": "./themes/darklight-hybrid-color-theme.json"
            },
            {
                "label": "DarkLight Hybrid Reverse",
                "uiTheme": "vs-dark",
                "path": "./themes/darklight-hybrid-reverse-color-theme.json"
            },
            {
                "label": "DarkLight Hybrid Reverse (Original Editor Text)",
                "uiTheme": "vs-dark",
                "path": "./themes/darklight-hybrid-reverse-original-editor-text-color-theme.json"
            }
        ]
    },
    "scripts": {
        "package": "vsce package",
        "publish:vsce": "vsce publish"
    },
    "devDependencies": {
        "@vscode/vsce": "^3.6.2"
    }
}